# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to a public repo.

# Port the server listens on (most hosts set this automatically)
PORT=3000

# A secret string YOU invent — put the same value in the Meta Developer
# Console webhook setup screen ("Verify Token").
WEBHOOK_VERIFY_TOKEN=isl-global-verify-2026

# ---- WhatsApp Cloud API (from Meta Developer Console > WhatsApp > API Setup) ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ---- Facebook Page / Messenger (from Meta Developer Console > Messenger) ----
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ---- Instagram (uses the same Graph API app as Facebook) ----
INSTAGRAM_ACCESS_TOKEN=

# Simple API key your CRM frontend sends back to this server (choose any string)
CRM_API_KEY=change-me
